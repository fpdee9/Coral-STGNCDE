graph TD
    %% --- Data Sources ---
    subgraph Sources ["Data Sources"]
        NOAA["NOAA ERDDAP Server<br/>(Satellite Data)"]
        BioDB["Biological Survey Records<br/>(Diver Data)"]
        Geo["Site Metadata<br/>(Lat/Lon Coordinates)"]
    end

    %% --- Environmental Processing ---
    subgraph EnvProc ["Environmental Processing (Continuous)"]
        NOAA -->|Request: SST & DHW| Chunk["Monthly Chunking Algorithm"]
        Chunk -->|Robust Retry| Download["Raw NetCDF/CSV Download"]
        Download -->|Filter by Lat/Lon| Extract["Extract 5km Pixel Values"]
        Extract -->|Impute NaN| CleanEnv["Cleaned Env History<br/>1985-2024"]
    end

    %% --- Biological Processing ---
    subgraph BioProc ["Biological Processing (Sparse)"]
        BioDB -->|Load CSV| Norm["Normalization"]
        Norm -->|Standardize 0-1| FilterBio["Filter for Hard Coral Cover"]
        FilterBio -->|Group by Site| SparseBio["Sparse Bio Time-Series"]
    end

    %% --- Spatial Processing ---
    subgraph SpatialProc ["Spatial Processing"]
        Geo -->|Haversine Formula| DistMat["Distance Matrix"]
        DistMat -->|Thresholding| AdjMat["Adjacency Matrix (Graph)"]
    end

    %% --- Integration ---
    subgraph Integration ["Data Integration & Tensor Construction"]
        CleanEnv & SparseBio -->|Align by Date| Merged["Merged Spatio-Temporal Dataset"]
        
        Merged -->|Downsample| Weekly["Weekly Aggregation (Steps=2087)"]
        
        Weekly --> TensorX["Tensor X<br/>(Env Drivers)"]
        Weekly --> TensorY["Tensor Y<br/>(Coral Truth)"]
        Weekly --> Mask["Tensor Mask<br/>(1=Observed, 0=Missing)"]
    end

    %% --- Final Output ---
    AdjMat --> ModelInput
    TensorX --> ModelInput
    TensorY --> ModelInput
    Mask --> ModelInput
    
    ModelInput["<b>Final Model Inputs (.pt)</b><br/>Ready for Neural CDE"]

    style NOAA fill:#e1f5fe,stroke:#01579b
    style BioDB fill:#e8f5e9,stroke:#1b5e20
    style ModelInput fill:#fff9c4,stroke:#fbc02d,stroke-width:2px